    VIDEO ||--o{ VIDEO_TAG_RELATION : "标签"
    VIDEO_TAG ||--o{ VIDEO_TAG_RELATION : "标记"
    VIDEO ||--o{ COMMENT : "评论"
    COMMENT ||--o| COMMENT : "回复"
    VIDEO ||--o{ RATING : "评分"
    VIDEO ||--o{ MATERIAL : "资料"
    VIDEO ||--o{ NOTE : "笔记"
    VIDEO ||--o{ WATCH_HISTORY : "记录"
