    USER ||--o{ OPERATION_LOG : "记录"
    USER ||--o{ COMMENT : "发表"
    USER ||--o{ RATING : "评分"
    USER ||--o{ NOTE : "笔记"
    USER ||--o{ WATCH_HISTORY : "观看"

    INSTRUCTOR ||--o{ VIDEO : "讲授"
    VIDEO_CATEGORY ||--o{ VIDEO : "包含"
